package tmplsessions

import "github.com/mwantia/forge/internal/application/ui/templates/layout"

// PluginPicker renders a multi-select dropdown for choosing plugins.
// Selected plugins are submitted as repeated "plugins" form fields
// and also dispatched via 'multiselect-change' for client-side filtering.
templ PluginPicker(availablePlugins []string) {
	@layout.MultiSelect(availablePlugins, []string{}, "plugins", "Add plugin…")
}
