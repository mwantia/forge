    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Forge Agent",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "./cmd/forge",
            "internalConsoleOptions": "neverOpen",
            "args": ["agent", "--config", "./tests/config.hcl", "--log-level", "TRACE"],
            "env": {},
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Forge Sandbox",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "./cmd/forge",
            "internalConsoleOptions": "neverOpen",
            "args": ["sandbox", "--path", "./tests/config.hcl", "--log-level", "TRACE", "--model", "ollama/glm-5:cloud", "\"List out the files of the current directory\""],
            "env": {},
            "cwd": "${workspaceFolder}"
        }
    ]
}